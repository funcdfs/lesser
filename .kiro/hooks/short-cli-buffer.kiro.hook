{
  "enabled": true,
  "name": "缩短命令行输入",
  "description": "在执行命令行操作前提醒 agent 将长命令拆分成多个短命令执行，避免命令行缓冲区卡顿",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "如果需要执行命令行操作，请注意：1) 将长命令拆分成多个短命令分步执行；2) 避免一次性向命令行缓冲区输入过多内容；3) 每个命令尽量简短，防止终端卡顿。"
  }
}