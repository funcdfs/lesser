# ============================================================================
# Environment Variables (统一放在 infra/env/ 目录下)
# ============================================================================
# 忽略所有 .env 文件，除了 example 模板
.env
.env.*
!.env.example
!.env.*.example

# 保留 infra/env 目录下的 example 文件
infra/env/*.env
!infra/env/*.env.example

# 忽略旧位置的环境变量文件
infra/.env.dev
infra/.env.prod
infra/.env.local

# ============================================================================
# Generated Code (Proto / gRPC)
# ============================================================================
# Python generated proto files
service/core_django/generated/protos/*.py
service/core_django/generated/protos/**/*.py
!service/core_django/generated/protos/__init__.py
!service/core_django/generated/__init__.py

# Go generated proto files
service/chat_gin/generated/
service/chat_gin/pkg/proto/

# Flutter generated proto files
client/mobile_flutter/lib/generated/

# React generated proto files
client/web_react/src/generated/

