# ============================================================================
# 开发环境配置 - Development Environment Configuration
# ============================================================================

# ============================================================================
# Database - PostgreSQL
# ============================================================================
POSTGRES_USER=lesser
POSTGRES_PASSWORD=lesser_dev_password
POSTGRES_DB=lesser_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://lesser:lesser_dev_password@postgres:5432/lesser_db

# ============================================================================
# Cache - Redis
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_CHAT_DB=1
REDIS_CACHE_DB=2

# ============================================================================
# Django Core Service
# ============================================================================
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django,*
DJANGO_PORT=8000
DJANGO_GRPC_PORT=50051
DJANGO_SETTINGS_MODULE=config.settings.dev

# ============================================================================
# Go Chat Service
# ============================================================================
CHAT_HTTP_PORT=8080
CHAT_GRPC_PORT=50052
CHAT_WS_PORT=8080
AUTH_GRPC_ADDR=django:50051

# ============================================================================
# Traefik Gateway
# ============================================================================
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8088
TRAEFIK_GRPC_PORT=50050

# ============================================================================
# JWT Configuration
# ============================================================================
JWT_SECRET_KEY=jwt-dev-secret-key-change-in-production
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# ============================================================================
# Celery Configuration
# ============================================================================
CELERY_BROKER_URL=redis://redis:6379/3
CELERY_RESULT_BACKEND=redis://redis:6379/4

# ============================================================================
# External Ports (Host Machine)
# ============================================================================
EXTERNAL_HTTP_PORT=80
EXTERNAL_DJANGO_PORT=8000
EXTERNAL_CHAT_PORT=8081
EXTERNAL_POSTGRES_PORT=5432
EXTERNAL_REDIS_PORT=6379
