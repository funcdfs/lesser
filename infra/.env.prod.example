# ============================================================================
# 生产环境配置模板 - Production Environment Configuration Template
# ============================================================================
# IMPORTANT: Copy this file to .env.prod and fill in actual values
# DO NOT commit .env.prod to version control
# ============================================================================

# ============================================================================
# Database - PostgreSQL
# ============================================================================
POSTGRES_USER=lesser_prod
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
POSTGRES_DB=lesser_prod_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://lesser_prod:<PASSWORD>@postgres:5432/lesser_prod_db

# ============================================================================
# Cache - Redis
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_CHAT_DB=1
REDIS_CACHE_DB=2

# ============================================================================
# Go Services
# ============================================================================
CHAT_HTTP_PORT=8080
CHAT_GRPC_PORT=50052
CHAT_WS_PORT=8080
GATEWAY_GRPC_PORT=50053

# ============================================================================
# Traefik Gateway
# ============================================================================
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_GRPC_PORT=50050

# ============================================================================
# SSL/TLS Configuration
# ============================================================================
ACME_EMAIL=<YOUR_EMAIL_FOR_LETSENCRYPT>
DOMAIN=your-domain.com

# ============================================================================
# JWT Configuration
# ============================================================================
JWT_SECRET_KEY=<CHANGE_ME_GENERATE_STRONG_JWT_SECRET>
JWT_ACCESS_TOKEN_LIFETIME=1800
JWT_REFRESH_TOKEN_LIFETIME=604800

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=WARNING
SENTRY_DSN=<YOUR_SENTRY_DSN_IF_USING>

# ============================================================================
# External Ports (Host Machine)
# ============================================================================
EXTERNAL_HTTP_PORT=80
EXTERNAL_HTTPS_PORT=443
EXTERNAL_GRPC_PORT=50050
