# ============================================================================
# 生产环境配置模板 - Production Environment Configuration Template
# 复制此文件为 prod.env 并填入实际值
# Copy this file to prod.env and fill in actual values
# ⚠️ 警告: 生产环境必须使用强密码和安全密钥
# ⚠️ WARNING: Production MUST use strong passwords and secure keys
# gRPC 全面迁移后的配置
# ============================================================================

# ============================================================================
# Database - PostgreSQL (Multi-Database)
# ============================================================================
POSTGRES_USER=lesser_prod
POSTGRES_PASSWORD=<CHANGE_TO_STRONG_PASSWORD>
POSTGRES_DB=lesser_prod_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Chat Service 使用的独立数据库
CHAT_DATABASE_URL=postgres://lesser_prod:<PASSWORD>@postgres:5432/lesser_chat_db

# ============================================================================
# Cache - Redis
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_TO_STRONG_PASSWORD>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_CHAT_DB=1
REDIS_CACHE_DB=2

# ============================================================================
# Message Broker - RabbitMQ (仅用于次要异步任务)
# ============================================================================
RABBITMQ_USER=funcdfs
RABBITMQ_PASSWORD=<CHANGE_TO_STRONG_PASSWORD>
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/

# ============================================================================
# Gateway Service (统一 API 入口)
# ============================================================================
GATEWAY_GRPC_PORT=50053

# ============================================================================
# Auth Service (认证服务)
# ============================================================================
AUTH_GRPC_PORT=50054
JWT_ACCESS_TOKEN_LIFETIME=1800
JWT_REFRESH_TOKEN_LIFETIME=86400

# ============================================================================
# User Service (用户服务)
# ============================================================================
USER_GRPC_PORT=50055

# ============================================================================
# Content Service (内容服务)
# ============================================================================
CONTENT_GRPC_PORT=50056

# ============================================================================
# Interaction Service (交互服务)
# ============================================================================
INTERACTION_GRPC_PORT=50060

# ============================================================================
# Comment Service (评论服务)
# ============================================================================
COMMENT_GRPC_PORT=50061

# ============================================================================
# Timeline Service (时间线服务)
# ============================================================================
TIMELINE_GRPC_PORT=50062

# ============================================================================
# Search Service (搜索服务)
# ============================================================================
SEARCH_GRPC_PORT=50058

# ============================================================================
# Notification Service (通知服务)
# ============================================================================
NOTIFICATION_GRPC_PORT=50059

# ============================================================================
# Chat Service (聊天服务 - gRPC 双向流)
# ============================================================================
CHAT_GRPC_PORT=50052
AUTH_GRPC_ADDR=auth:50054

# ============================================================================
# Traefik Gateway
# ============================================================================
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8088
TRAEFIK_GRPC_PORT=50050

# ============================================================================
# SSL/TLS Configuration
# ============================================================================
SSL_CERT_PATH=/etc/ssl/certs/your-domain.crt
SSL_KEY_PATH=/etc/ssl/private/your-domain.key

# ============================================================================
# External Ports (Host Machine)
# ============================================================================
EXTERNAL_GATEWAY_PORT=50053
EXTERNAL_POSTGRES_PORT=5432
EXTERNAL_REDIS_PORT=6379
EXTERNAL_RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================================================
# Monitoring & Logging
# ============================================================================
LOG_LEVEL=WARNING
SENTRY_DSN=<YOUR_SENTRY_DSN>

# PgHero - PostgreSQL 性能监控
PGHERO_USERNAME=<CHANGE_TO_STRONG_USERNAME>
PGHERO_PASSWORD=<CHANGE_TO_STRONG_PASSWORD>
