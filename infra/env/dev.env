# ============================================================================
# 开发环境配置 - Development Environment Configuration
# ============================================================================

# ============================================================================
# 全局管理员凭据 (所有服务统一使用此凭据)
# ============================================================================
ADMIN_USER=funcdfs
ADMIN_PASSWORD=fw142857
ADMIN_EMAIL=funcdfs@gmail.com

# ============================================================================
# Database - PostgreSQL
# ============================================================================
POSTGRES_USER=funcdfs
POSTGRES_PASSWORD=fw142857
POSTGRES_DB=lesser_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Chat Service 独立数据库
CHAT_DATABASE_URL=postgres://funcdfs:fw142857@postgres:5432/lesser_chat_db

# ============================================================================
# Cache - Redis
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_CHAT_DB=1
REDIS_CACHE_DB=2

# ============================================================================
# Message Broker - RabbitMQ
# ============================================================================
RABBITMQ_USER=funcdfs
RABBITMQ_PASSWORD=fw142857
RABBITMQ_URL=amqp://funcdfs:fw142857@rabbitmq:5672/

# ============================================================================
# Service Ports
# ============================================================================
# Gateway: 50051, Auth: 50052, User: 50053, Content: 50054, Comment: 50055
# Interaction: 50056, Timeline: 50057, Search: 50058, Notification: 50059
# Chat: 50060, SuperUser: 50061, Channel: 50062
# ============================================================================
GATEWAY_GRPC_PORT=50051
AUTH_GRPC_PORT=50052
USER_GRPC_PORT=50053
CONTENT_GRPC_PORT=50054
COMMENT_GRPC_PORT=50055
INTERACTION_GRPC_PORT=50056
TIMELINE_GRPC_PORT=50057
SEARCH_GRPC_PORT=50058
NOTIFICATION_GRPC_PORT=50059
CHAT_GRPC_PORT=50060
SUPERUSER_GRPC_PORT=50061
CHANNEL_GRPC_PORT=50062

# Auth 服务地址 (供其他服务调用)
AUTH_GRPC_ADDR=auth:50052

# JWT 配置
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# ============================================================================
# Traefik Gateway
# ============================================================================
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8088
TRAEFIK_GRPC_PORT=50050

# ============================================================================
# External Ports (Host Machine)
# ============================================================================
EXTERNAL_GATEWAY_PORT=50051
EXTERNAL_POSTGRES_PORT=5432
EXTERNAL_REDIS_PORT=6379
EXTERNAL_RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
DOZZLE_PORT=9999

# ============================================================================
# Dev Tools
# ============================================================================
# Jaeger
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

# RedisInsight
REDISINSIGHT_PORT=5540

# PgHero
PGHERO_PORT=8080
PGHERO_USERNAME=funcdfs
PGHERO_PASSWORD=fw142857

# ============================================================================
# SuperUser Service 配置
# ============================================================================
SUPERUSER_USERNAME=funcdfs
SUPERUSER_EMAIL=funcdfs@gmail.com
SUPERUSER_PASSWORD=fw142857
SUPERUSER_DISPLAY_NAME=funcdfs
SUPERUSER_JWT_SECRET=superuser-secret-key-change-in-production
