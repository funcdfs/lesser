# ============================================================================
# 开发环境配置模板 - Development Environment Configuration Template
# 复制此文件为 dev.env 并填入实际值
# Copy this file to dev.env and fill in actual values
# gRPC 全面迁移后的配置
# ============================================================================

# ============================================================================
# Database - PostgreSQL (Multi-Database)
# ============================================================================
POSTGRES_USER=lesser
POSTGRES_PASSWORD=lesser_dev_password
POSTGRES_DB=lesser_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Chat Service 使用的独立数据库
CHAT_DATABASE_URL=postgres://lesser:lesser_dev_password@postgres:5432/lesser_chat_db

# ============================================================================
# Cache - Redis
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_CHAT_DB=1
REDIS_CACHE_DB=2

# ============================================================================
# Message Broker - RabbitMQ (仅用于次要异步任务)
# ============================================================================
RABBITMQ_USER=funcdfs
RABBITMQ_PASSWORD=fw142857
RABBITMQ_URL=amqp://funcdfs:fw142857@rabbitmq:5672/

# ============================================================================
# Gateway Service (统一 API 入口)
# ============================================================================
GATEWAY_GRPC_PORT=50053

# ============================================================================
# Auth Service (认证服务)
# ============================================================================
AUTH_GRPC_PORT=50054
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# ============================================================================
# User Service (用户服务)
# ============================================================================
USER_GRPC_PORT=50055

# ============================================================================
# Content Service (内容服务)
# ============================================================================
CONTENT_GRPC_PORT=50056

# ============================================================================
# Interaction Service (交互服务)
# ============================================================================
INTERACTION_GRPC_PORT=50060

# ============================================================================
# Comment Service (评论服务)
# ============================================================================
COMMENT_GRPC_PORT=50061

# ============================================================================
# Timeline Service (时间线服务)
# ============================================================================
TIMELINE_GRPC_PORT=50062

# ============================================================================
# Search Service (搜索服务)
# ============================================================================
SEARCH_GRPC_PORT=50058

# ============================================================================
# Notification Service (通知服务)
# ============================================================================
NOTIFICATION_GRPC_PORT=50059

# ============================================================================
# Chat Service (聊天服务 - gRPC 双向流)
# ============================================================================
CHAT_GRPC_PORT=50052
AUTH_GRPC_ADDR=auth:50054

# ============================================================================
# Traefik Gateway
# ============================================================================
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8088
TRAEFIK_GRPC_PORT=50050

# ============================================================================
# External Ports (Host Machine)
# ============================================================================
EXTERNAL_GATEWAY_PORT=50053
EXTERNAL_POSTGRES_PORT=5432
EXTERNAL_REDIS_PORT=6379
EXTERNAL_RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
DOZZLE_PORT=9999

# ============================================================================
# Dev Tools
# ============================================================================
# Jaeger - 分布式链路追踪
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

# RedisInsight - Redis 可视化管理
REDISINSIGHT_PORT=5540

# PgHero - PostgreSQL 性能监控
PGHERO_PORT=8080
PGHERO_USERNAME=funcdfs
PGHERO_PASSWORD=fw142857
