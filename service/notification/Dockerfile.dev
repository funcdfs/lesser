FROM golang:1.24-alpine

RUN apk add --no-cache git netcat-openbsd

# 安装 air 用于热重载
RUN go install github.com/air-verse/air@v1.61.7

WORKDIR /app

# 复制 go.mod 文件
COPY notification/go.mod ./notification/
COPY pkg/go.mod ./pkg/

# 下载依赖
WORKDIR /app/notification
RUN go mod download || true

WORKDIR /app/notification

EXPOSE 50059

CMD ["air", "-c", ".air.toml"]
