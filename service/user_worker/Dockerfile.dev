# Development Dockerfile with hot reload and package caching
FROM golang:1.24-alpine

# Install dependencies
RUN apk add --no-cache git ca-certificates tzdata

# Install air for hot reload (v1.61.7 is compatible with Go 1.24)
RUN go install github.com/air-verse/air@v1.61.7

WORKDIR /app

# Source code and pkg will be mounted via volume
# Run with air for hot reload, first update go.mod replace directive
CMD ["sh", "-c", "sed -i 's|replace github.com/lesser/pkg => ../pkg|replace github.com/lesser/pkg => /pkg|g' go.mod && go mod download && air -c .air.toml"]
