FROM golang:1.24-alpine

RUN apk add --no-cache git netcat-openbsd

# 安装 air 用于热重载
RUN go install github.com/air-verse/air@v1.61.7

WORKDIR /app

# 复制整个 service 目录的 go.mod 文件
COPY auth/go.mod ./auth/
COPY pkg/go.mod ./pkg/

# 下载依赖
WORKDIR /app/auth
RUN go mod download || true

WORKDIR /app/auth

EXPOSE 50054

CMD ["air", "-c", ".air.toml"]
