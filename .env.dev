# ============================================================================
# Lesser 项目统一开发环境配置文件
# ============================================================================
# 
# 此文件用于统一管理所有服务的配置参数，包括：
#   - PostgreSQL 数据库配置
#   - Redis 缓存配置
#   - Django 应用配置
#   - API Gateway (APISIX) 配置
#   - Flutter 应用配置
#
# 使用方法：
#   1. 在项目根目录运行: ./dev.sh start
#   2. dev.sh 会自动加载此文件的配置
#   3. 所有服务都会读取这些参数
#
# 注意事项：
#   - 敏感信息（密码）应该保管好，不要提交到公共仓库
#   - 生产环境应使用更强的密码
#   - 修改此文件后需要重启服务才能生效

# ============================================================================
# 数据库配置 - PostgreSQL
# ============================================================================
POSTGRES_USER=funcdfs
POSTGRES_PASSWORD=fw142857
POSTGRES_DB=lesser_db
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# ============================================================================
# 缓存配置 - Redis
# ============================================================================
REDIS_USER=funcdfs
REDIS_PASSWORD=fw142857
REDIS_PORT=6379
REDIS_HOST=redis

# ============================================================================
# Django 应用配置
# ============================================================================
DJANGO_SECRET_KEY=django-insecure-72c10ff#d^2wmf%17^3%*y!+a3jeb6mr&5+rd-3g7g12t&e=ad
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_LOG_LEVEL=INFO

# ============================================================================
# APISIX API Gateway 配置
# ============================================================================
APISIX_ADMIN_API=http://localhost:9180
APISIX_GATEWAY_URL=http://localhost:9080

# ============================================================================
# etcd 配置中心
# ============================================================================
ETCD_HOST=etcd
ETCD_PORT=2379
ETCD_ENDPOINTS=http://etcd:2379

# ============================================================================
# 域名配置
# ============================================================================
BASE_DOMAIN=localhost

# ============================================================================
# API 配置 - Flutter 使用
# ============================================================================
# 开发环境 API 基础 URL
# - 本地开发: http://localhost:9080/api (通过 APISIX 网关)
# - 生产环境: https://api.example.com (通过生产网关)
API_BASE_URL=http://localhost:9080/api
API_TIMEOUT=30000

# ============================================================================
# 服务端口配置
# ============================================================================
# Django 应用端口
DJANGO_PORT=8000
DJANGO_EXTERNAL_PORT=8001

# APISIX Gateway 端口
APISIX_HTTP_PORT=9080
APISIX_HTTPS_PORT=9443
APISIX_ADMIN_PORT=9180

# APISIX Dashboard 端口
APISIX_DASHBOARD_PORT=9000

# PostgreSQL 端口
# POSTGRES_PORT=5432 (已在上面定义)

# Redis 端口
# REDIS_PORT=6379 (已在上面定义)

# etcd 端口
# ETCD_PORT=2379 (已在上面定义)

# ============================================================================
# Traefik 配置 (如果需要替代或并用)
# ============================================================================
TRAEFIK_ENTRYPOINT_HTTP=80
TRAEFIK_ENTRYPOINT_HTTPS=443

# ============================================================================
# 日志配置
# ============================================================================
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# ============================================================================
# 功能开关 - 用于条件启用某些功能
# ============================================================================
ENABLE_DEBUG_TOOLBAR=True
ENABLE_SWAGGER_UI=True
ENABLE_APISIX_DASHBOARD=True
